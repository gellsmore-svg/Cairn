{
  "name": "customer-po-review-layout",
  "baseUrl": "http://localhost:5173",
  "output": "../analysis/customer-po-review-ui-sim-report.json",
  "timeout": 30000,
  "viewport": {
    "width": 1440,
    "height": 900
  },
  "steps": [
    {
      "action": "assertVisible",
      "label": "Open PO review detail",
      "selector": "#po-review-detail",
      "humanLoad": {
        "phase": "orientation",
        "systems": ["attention", "working memory"],
        "demand": "The coordinator must orient to customer identity, PO number, duplicate risk, and available next action."
      }
    },
    {
      "action": "measureLayout",
      "label": "Measure PO decision layout",
      "elements": [
        {"id": "po_label", "selector": "#po-label", "role": "label", "label": "PO Number"},
        {"id": "po_number", "selector": "#po-number", "role": "field", "label": "PO Number"},
        {"id": "customer_account", "selector": "#customer-account", "role": "field", "label": "Customer Account"},
        {"id": "line_exceptions", "selector": "#line-exceptions", "role": "evidence", "label": "Line Exceptions"},
        {"id": "duplicate_warning", "selector": "#duplicate-warning", "role": "warning", "label": "Possible Duplicate PO"},
        {"id": "accept_action", "selector": "#accept-po", "role": "button", "label": "Accept PO"},
        {"id": "repair_action", "selector": "#request-repair", "role": "button", "label": "Request Repair"}
      ],
      "relations": [
        {"from": "po_label", "to": "po_number", "type": "label_for"},
        {"from": "po_number", "to": "duplicate_warning", "type": "related"},
        {"from": "customer_account", "to": "duplicate_warning", "type": "related"},
        {"from": "line_exceptions", "to": "accept_action", "type": "evidence_to_action"},
        {"from": "duplicate_warning", "to": "accept_action", "type": "evidence_to_action"}
      ],
      "sequence": ["po_number", "customer_account", "line_exceptions", "duplicate_warning", "accept_action"]
    },
    {
      "action": "finding",
      "label": "PO layout review finding",
      "value": {
        "risk": "Duplicate warning and exception evidence are too far from the accept action, so the operator may approve before integrating the relevant risk cues.",
        "probability": "medium",
        "impact": "high",
        "mitigation": "Group PO identity, duplicate warning, line exceptions, and accept/repair actions in one decision panel."
      }
    }
  ]
}
